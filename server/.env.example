# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# MongoDB connection string
# Railway: use the reference variable ${{MongoDB.MONGO_URI}}
MONGO_URI=mongodb://localhost:27017/hirerank

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET=change-me

# Optional GitHub Personal Access Token — raises API rate limit from 60 to 5000 req/hr
GITHUB_TOKEN=

# Organisation access code required at registration
ORG_ACCESS_CODE=HIRERANK-2026

# Port the Express server listens on (Railway injects $PORT automatically)
PORT=5000

# Allowed CORS origin for the frontend — leave blank to allow all origins (*)
CLIENT_ORIGIN=http://localhost:3000
